## =============================================
## .gitignore generico para proyectos C# / .NET
## Visual Studio 2022 (Windows Forms, WPF, Console, etc.)
## =============================================

# ---------- Directorios de compilacion ----------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/

# ---------- Visual Studio ----------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# ---------- Archivos de cache y temporales ----------
*.cache
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
project.lock.json
project.fragment.lock.json
artifacts/

# ---------- NuGet ----------
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nupkg
**/packages/repositories.config

# ---------- MSBuild ----------
*.log
msbuild.binlog
[Dd]ebugPublic/

# ---------- Build Results ----------
[Bb]uild[Ll]og.*
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# ---------- Test Results ----------
[Tt]est[Rr]esult*/
*.trx
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# ---------- .NET Core / .NET 5+ ----------
project.nuget.cache
*.razor.g.cs

# ---------- Publish / Deploy ----------
[Pp]ublish/
*.azurePubxml
*.pubxml
!**/[Pp]ublish[Pp]rofiles/
*.publishproj

# ---------- ClickOnce ----------
*.application
*.manifest

# ---------- Code Coverage ----------
*.coverage
*.coveragexml

# ---------- StyleCop ----------
StyleCopReport.xml

# ---------- Archivos generados por herramientas ----------
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# ---------- SQL Server ----------
*.mdf
*.ldf
*.ndf

# ---------- Windows ----------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ---------- JetBrains Rider ----------
.idea/
*.sln.iml

# ---------- macOS ----------
.DS_Store
